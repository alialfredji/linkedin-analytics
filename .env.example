# LinkedIn credentials — used for initial login and cookie refresh
LINKEDIN_USERNAME=your@email.com
LINKEDIN_PASSWORD=yourpassword

# Paths inside the container (mapped to ./data/ volume)
DB_PATH=/data/linkedin.db
DASHBOARD_PATH=/data/dashboard.html
COOKIE_PATH=/data/cookies.json

# Cron schedule for daily extraction (default: 6am UTC)
# Follows standard cron syntax: minute hour day month weekday
CRON_SCHEDULE=0 6 * * *
